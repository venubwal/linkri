#
# System configurations for the Enterprise Platform.

# Security configuration
authentication_scheme=basic
authentication_enabled=false

# =========================================================================
# Upstash Kafka Configurations (console.upstash.com)
# =========================================================================
# Enable remote cloud Kafka by populating these from your Upstash console.
# If these properties are empty or default, connection falls back to localhost.
upstash.kafka.bootstrap-servers=your-upstash-kafka-bootstrap-server.upstash.io:9092
upstash.kafka.username=token
upstash.kafka.password=your-upstash-token
upstash.kafka.topic=analytics-topic

# Upstash REST Management API for topic automation
upstash.kafka.rest-url=https://api.upstash.com/v2/kafka
upstash.kafka.rest-token=your-upstash-management-token
upstash.kafka.cluster-id=your-upstash-cluster-id
